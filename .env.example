# Copy to .env.local to override anything below (optional; .env.local is gitignored).
#
# How it works:
# - npm run dev     → loads .env.development  (local API: http://localhost:8080)
# - npm run build   → loads .env.production   (Render API URL)
# - Vercel / CI     → set NEXT_PUBLIC_API_BASE_URL in the dashboard if you prefer (overrides file at build time)
#
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
