# Build context — keep secrets and dev-only files out of `docker build` (and out of any COPY).
.git
.github
.gitignore

node_modules
.next
out
.turbo
.vercel
coverage
.nyc_output

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

.env
.env.*
!.env.example

README.md
*.md
Dockerfile*
.dockerignore
frontend-ci.yml

.DS_Store
Thumbs.db

# Keys / local credentials (defense in depth; Dockerfile uses explicit COPY, not COPY . .)
*.pem
*.key
*.p12
*.pfx
secrets
credentials
